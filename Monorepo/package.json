{
  "name": "monorepo-framework",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "serve": "node examples/server.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "turbo": "latest",
    "typescript": "^5.9.3"
  }
}
