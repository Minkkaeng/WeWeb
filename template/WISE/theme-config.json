{
  "theme": "dark",
  "colors": {
    "primary": "#FFD200",
    "secondary": "#E10019",
    "background": "#000000",
    "surface": "#1A1A1A",
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#A0A0A0",
      "accent": "#FFD200"
    },
    "border": "#333333"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif"
    },
    "fontSize": {
      "hero": "clamp(3rem, 10vw, 8rem)",
      "h1": "4rem",
      "h2": "2.5rem",
      "body": "1rem"
    },
    "fontWeight": {
      "bold": "800",
      "medium": "500",
      "normal": "400"
    }
  },
  "spacing": {
    "container": "1200px",
    "gutter": "2rem",
    "section": "8rem"
  },
  "animations": {
    "duration": {
      "slow": "0.6s",
      "normal": "0.3s",
      "fast": "0.1s"
    },
    "ease": "cubic-bezier(0.23, 1, 0.32, 1)"
  }
}
